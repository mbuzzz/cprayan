# .env.production template
# COPY THIS FILE TO .env ON THE SERVER BEFORE RUNNING DOCKER COMPOSE

# Database (Keep SQLite for now as requested, adjust if moving to Postgres)
DATABASE_URL="file:./dev.db"

# NextAuth Settings
# Generate a secret using: openssl rand -base64 32
NEXTAUTH_SECRET="ganti_dengan_secret_yang_sangat_panjang_dan_acak_disini"

# Set to your domain name when deployed (e.g. https://rayanweb.id)
# NEXTAUTH_URL="http://localhost:3000"
